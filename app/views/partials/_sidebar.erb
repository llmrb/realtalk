<aside class="hidden shrink-0 self-start lg:sticky lg:top-6 lg:flex lg:w-56 lg:flex-col lg:pt-2">
  <div class="panel flex flex-col items-center gap-10 px-4 py-5">
    <a
      href="https://www.youtube.com/watch?v=CyzdOtyYnng"
      target="_blank"
      rel="noreferrer noopener"
      aria-label="Relay home"
      class="block"
    >
      <img
        class="max-h-16 w-auto max-w-[11rem] rounded-2xl shadow-sm"
        src="/images/relay.png"
        alt="Relay"
      >
    </a>
    <% if show_controls %>
      <form class="flex w-full flex-col gap-4 text-sm text-zinc-300">
        <div id="providers-control" class="flex flex-col gap-2" hx-get="/providers" hx-trigger="load" hx-swap="outerHTML">
          <span class="label">Provider</span>
          <div class="field text-zinc-500">Loading...</div>
        </div>
        <div id="models-control" class="flex flex-col gap-2" hx-get="/models" hx-trigger="load" hx-swap="outerHTML">
          <span class="label">Model</span>
          <div class="py-1 text-sm font-medium text-zinc-500">Loading...</div>
        </div>
      </form>
    <% end %>
  </div>
</aside>
