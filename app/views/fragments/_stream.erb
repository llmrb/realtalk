<div
  id="chatbot-stream"
  hx-swap-oob="outerHTML"
  class="scrollbar-chat h-full min-h-24 min-w-0 flex-1 self-stretch overflow-y-auto rounded-3xl border border-zinc-800/90 bg-zinc-950/80 p-4 text-[15px] leading-7 shadow-[0_18px_40px_rgba(0,0,0,0.28)]"
>
  <div class="space-y-4">
    <div class="mt-3 text-center text-xs text-zinc-100 first:mt-0">
      Welcome to Relay
      <br>
      <%= session["provider"] %> / <%= session["model"] %>
    </div>
    <% messages.each do |message| %>
      <% if message[:role] == :user %>
        <div class="mt-3 flex justify-end first:mt-0">
          <div class="w-fit max-w-[75%] rounded-3xl rounded-br-lg border border-emerald-500/30 bg-emerald-500/12 px-4 py-3 text-emerald-50 leading-7 shadow-[0_12px_30px_rgba(0,0,0,0.18)] [&_*]:text-emerald-50">
            <div class="assistant-content" data-markdown data-markdown-source="<%= message[:content] %>"></div>
          </div>
        </div>
      <% else %>
        <div class="mt-3 flex first:mt-0">
          <div class="assistant-content w-fit max-w-[85%] rounded-3xl rounded-bl-lg border border-zinc-800 bg-zinc-900/85 px-4 py-3 text-zinc-100 leading-7 shadow-[0_12px_30px_rgba(0,0,0,0.18)]">
            <div data-markdown data-markdown-source="<%= message[:content] %>"></div>
          </div>
        </div>
      <% end %>
    <% end %>
    <% if messages.empty? %>
      <div class="px-2 text-sm leading-7 text-zinc-100">
        Ask a question, switch models, or explore the built-in tools.
      </div>
    <% end %>
  </div>
</div>
