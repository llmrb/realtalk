<div id="models-control" class="flex flex-col gap-2" hx-swap-oob="outerHTML">
  <span class="label">Model</span>
  <form class="w-full" hx-post="/settings/set-model" hx-trigger="change from:select">
    <select class="select-field" name="model">
      <% models.each do |model| %>
        <option
          <%= "selected" if model.id == session["model"] %>
          value="<%= model.id %>">
          <%= model.name %>
        </option>
      <% end %>
    </select>
  </form>
  <span class="text-[11px] text-stone-400"><%= models.size %> models available</span>
</div>
